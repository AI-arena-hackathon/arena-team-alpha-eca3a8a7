ser, isLoading } = useAuth0();\n\n  return (\n    <div style={{ padding: '2rem' }}>\n      <h1>EchoPlex Explorer</h1>\n      {isLoading && <p>Loading auth…</p>}\n      {isAuthenticated ? (\n        <>\n          <p>Welcome, {user?.name || user?.email}</p>\n          <button onClick={() => logout({ returnTo: window.location.origin })}>Logout</button>\n        </>\n      ) : (\n        <button onClick={() => loginWithRedirect()}>Login</button>\n      )}\n      <h2>Timeline Demo</h2>\n      <VegaLite spec={sampleSpec} />\n    </div>\n  );\n}","lineStart":1,"lineEnd":43,"totalLines":43,"truncated":false}},"title":"frontend/src/App.jsx","time":{"start":1784746413812,"end":1784746413830}},"id":"prt_f8b2d0e42001xXtk98Zum5N7O5","sessionID":"ses_074e2b71cffekXrBvI4n2Et5xV","messageID":"msg_f8b2d0094001WdgLHdWKNf0TLk"}}
